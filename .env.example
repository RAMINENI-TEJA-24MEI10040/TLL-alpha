# ============================================================
# Async Execution System — Environment Configuration
# ============================================================
# Copy this file to .env and customize for your environment.

# ---- Application ----
APP_NAME=API Security Testing Platform
APP_VERSION=1.0.0
DEBUG=false

# ---- Database ----
# Option A: SQLite (local dev — no external dependencies)
DATABASE_URL=sqlite+aiosqlite:///./test.db

# Option B: PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://executor_user:executor_password@localhost:5432/executor_db
# POSTGRES_USER=executor_user
# POSTGRES_PASSWORD=executor_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=executor_db

# ---- Redis ----
# If Redis is not available, the system auto-falls back to in-memory FakeRedis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# ---- Worker Configuration ----
WORKER_CONCURRENCY=100
WORKER_HEARTBEAT_INTERVAL=5
WORKER_TIMEOUT=30

# ---- Rate Limiting & Retry ----
DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_BACKOFF=2.0

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
